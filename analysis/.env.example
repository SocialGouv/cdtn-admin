# Copy this file to `.env` and fill in the real values.

# Matomo PostgreSQL connection (read-only analytics — event data on the replica)
PG_MATOMO_USER=
PG_MATOMO_PASSWORD=
PG_MATOMO_HOST=
PG_MATOMO_DB=
PG_MATOMO_PORT=5432

# Matomo HTTP Reporting API (per-URL page views — used by reports/contrib_weekly_views.py)
# base URL = Matomo root, e.g. https://matomo.example.gouv.fr (no trailing /index.php)
MATOMO_BASE_URL=
MATOMO_SITE_ID=
MATOMO_TOKEN_AUTH=
