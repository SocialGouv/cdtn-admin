# Copy this file to `.env` and fill in the real values.

# Matomo PostgreSQL connection (read-only analytics — event data on the replica)
PG_MATOMO_USER=
PG_MATOMO_PASSWORD=
PG_MATOMO_HOST=
PG_MATOMO_DB=
PG_MATOMO_PORT=5432

# Matomo HTTP Reporting API (per-URL page views — used by reports/contrib_monthly_views.py)
# base URL = Matomo root, e.g. https://matomo.example.gouv.fr (no trailing /index.php)
MATOMO_BASE_URL=
MATOMO_SITE_ID=
MATOMO_TOKEN_AUTH=

# Metabase PostgreSQL — DESTINATION written to by the ingest commands
# (ingest-simulateurs …). OPTIONAL locally: the defaults below already match the
# repo's `docker compose up -d metabase-db` (host port 5433). Set/override these
# only to target another database (e.g. a remote/staging Metabase).
METABASE_DB_HOST=localhost
METABASE_DB_PORT=5433
METABASE_DB_USER=metabase
METABASE_DB_PASSWORD=metabasepassword
METABASE_DB_NAME=metabase
